<platform name="msx" cpu="z80">
  <memory_map>
    <region start="0x0000" end="0x3FFF" type="rom" name="slot0_page0"/>
    <region start="0x4000" end="0x7FFF" type="rom" name="slot_page1"/>
    <region start="0x8000" end="0xBFFF" type="rom" name="slot_page2"/>
    <region start="0xC000" end="0xFFFF" type="ram" name="main_ram"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000">
    <entry index="0" name="rst00"/>
    <entry index="4" name="rst38_irq" irq="true"/>
  </vectors>

  <hardware_registers>
    <reg addr="0x98" width="1" name="vdp_data" access="rw"/>
    <reg addr="0x99" width="1" name="vdp_ctrl" access="rw"/>
    <reg addr="0xA0" width="1" name="psg_addr" access="w"/>
    <reg addr="0xA1" width="1" name="psg_data" access="w"/>
    <reg addr="0xA2" width="1" name="psg_read" access="r"/>
    <reg addr="0xA8" width="1" name="ppi_slot_select" access="rw"/>
  </hardware_registers>
</platform>
