<platform name="nes" cpu="6502">
  <memory_map>
    <region start="0x0000" end="0x07FF" type="ram" name="internal_ram"/>
    <region start="0x0800" end="0x1FFF" type="unmapped" name="ram_mirrors"/>
    <region start="0x2000" end="0x2007" type="io" name="ppu_registers"/>
    <region start="0x2008" end="0x3FFF" type="unmapped" name="ppu_mirrors"/>
    <region start="0x4000" end="0x4017" type="io" name="apu_io"/>
    <region start="0x4018" end="0x5FFF" type="io" name="mapper_io"/>
    <region start="0x6000" end="0x7FFF" type="ram" name="prg_ram"/>
    <region start="0x8000" end="0xFFFF" type="rom" name="prg_rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0xFFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

  <hardware_registers>
    <reg addr="0x2000" width="1" name="ppuctrl" access="w"/>
    <reg addr="0x2001" width="1" name="ppumask" access="w"/>
    <reg addr="0x2002" width="1" name="ppustatus" access="r"/>
    <reg addr="0x2003" width="1" name="oamaddr" access="w"/>
    <reg addr="0x2004" width="1" name="oamdata" access="rw"/>
    <reg addr="0x2005" width="1" name="ppuscroll" access="w"/>
    <reg addr="0x2006" width="1" name="ppuaddr" access="w"/>
    <reg addr="0x2007" width="1" name="ppudata" access="rw"/>
    <reg addr="0x4000" width="1" name="sq1_vol" access="w"/>
    <reg addr="0x4014" width="1" name="oamdma" access="w"/>
    <reg addr="0x4015" width="1" name="snd_chn" access="rw"/>
    <reg addr="0x4016" width="1" name="joy1" access="rw"/>
    <reg addr="0x4017" width="1" name="joy2" access="rw"/>
  </hardware_registers>
</platform>
