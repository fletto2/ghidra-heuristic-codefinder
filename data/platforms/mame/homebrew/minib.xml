<platform name="minib" cpu="6502">
  <!-- source: MAME homebrew/minib.cpp -->
  <!-- year: 2002 -->
  <memory_map>
    <region start="0x00000000" end="0x0000BFFF" type="ram" name="ram"/>
    <region start="0x0000C000" end="0x0000FFFF" type="rom" name="rom"/>
    <region start="0x0000FC00" end="0x0000FDFF" type="io" name="fred_r"/>
    <region start="0x0000FE30" end="0x0000FE3F" type="io" name="region_fe30"/>
    <region start="0x0000FE60" end="0x0000FE6F" type="io" name="map"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

  <!-- http://www.sprow.co.uk/bbc/minib.htm
