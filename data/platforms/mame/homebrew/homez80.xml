<platform name="homez80" cpu="z80">
  <!-- source: MAME homebrew/homez80.cpp -->
  <!-- year: 2008 -->
  <memory_map>
    <region start="0x00000000" end="0x00000FFF" type="rom" name="rom"/>
    <region start="0x00002000" end="0x000023FF" type="ram" name="videoram"/>
    <region start="0x00007000" end="0x0000700F" type="io" name="homez80_keyboard_r"/>
    <region start="0x00008000" end="0x0000FFFF" type="ram" name="ram"/>
  </memory_map>

