<platform name="gs6502" cpu="6502">
  <!-- source: MAME homebrew/gs6502.cpp -->
  <!-- year: 2013 -->
  <memory_map>
    <region start="0x00000000" end="0x00007FFF" type="ram" name="ram"/>
    <region start="0x0000A000" end="0x0000BFFF" type="io" name="read"/>
    <region start="0x0000C000" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>
</platform>
