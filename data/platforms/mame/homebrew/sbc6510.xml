<platform name="sbc6510" cpu="6510">
  <!-- source: MAME homebrew/sbc6510.cpp -->
  <!-- year: 2009 -->
  <memory_map>
    <region start="0x00000000" end="0x00000001" type="ram" name="ram"/>
    <region start="0x00000002" end="0x00000002" type="io" name="a2_r"/>
    <region start="0x00000003" end="0x0000DFFF" type="ram" name="ram"/>
    <region start="0x0000E000" end="0x0000E00F" type="io" name="read"/>
    <region start="0x0000E800" end="0x0000E800" type="io" name="address_w"/>
    <region start="0x0000EA00" end="0x0000EA00" type="io" name="data_r"/>
    <region start="0x0000F000" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

  <devices>
    <device type="sound" name="ay8910"/>
  </devices>

