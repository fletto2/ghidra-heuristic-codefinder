<platform name="mbeepc85b" cpu="z80">
  <!-- source: MAME ausnz/mbee.cpp -->
  <!-- year: 1985 -->
  <memory_map>
    <region start="0x00000000" end="0x00007FFF" type="ram" name="ram"/>
    <region start="0x00008000" end="0x00009FFF" type="rom" name="rom"/>
    <region start="0x0000A000" end="0x0000BFFF" type="ram" name="ram"/>
    <region start="0x0000C000" end="0x0000FFFF" type="io" name="pak_r"/>
  </memory_map>

  <devices>
    <device type="sound" name="sn76496"/>
  </devices>

