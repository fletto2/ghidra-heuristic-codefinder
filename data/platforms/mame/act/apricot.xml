  <!-- year: 1983 -->
  <memory_map>
    <region start="0x00000000" end="0x0003FFFF" type="ram" name="ram"/>
    <region start="0x000F0000" end="0x000F0FFF" type="ram" name="screen_buffer"/>
    <region start="0x000F8000" end="0x000FFFFF" type="rom" name="rom"/>
