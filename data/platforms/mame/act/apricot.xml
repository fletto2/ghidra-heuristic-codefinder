  <devices>
    <device type="disk" name="wd_fdc"/>
    <device type="io" name="i8255"/>
    <device type="serial" name="z80sio"/>
    <device type="sound" name="sn76496"/>
    <device type="video" name="hd6845"/>
    <device type="video" name="mc6845"/>
  </devices>

