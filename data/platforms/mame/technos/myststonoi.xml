<platform name="myststonoi" cpu="6502">
  <!-- source: MAME technos/mystston.cpp -->
  <!-- year: 1984 -->
  <memory_map>
    <region start="0x00000000" end="0x00001FFF" type="ram" name="ram"/>
    <region start="0x00002000" end="0x00002000" type="io" name="video_control_w"/>
    <region start="0x00002010" end="0x00002010" type="io" name="irq_clear_w"/>
    <region start="0x00002020" end="0x00002020" type="ram" name="writeonly"/>
    <region start="0x00002030" end="0x00002030" type="ram" name="writeonly"/>
    <region start="0x00002040" end="0x00002040" type="unmapped" name="nop_read"/>
    <region start="0x00002050" end="0x00002050" type="unmapped" name="unmapped"/>
    <region start="0x00002060" end="0x0000207F" type="ram" name="ram"/>
    <region start="0x00004000" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

  <devices>
    <device type="sound" name="ay8910"/>
  </devices>

  <!-- Technos Mysterious Stones hardware
driver by Nicola Salmoria
Notes:
The subtitle of the two sets is slightly different:
"Dr. John's Adventure" vs. "Dr. Kick in Adventure".
The Dr John's is a bug fix. See the routine at 4376/4384 for example.
The old set thrashes the Y register, the new one saves in on
the stack. The newer set also resets the audio chips more often. -->
</platform>
