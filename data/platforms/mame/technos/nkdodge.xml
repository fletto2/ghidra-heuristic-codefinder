<platform name="nkdodge" cpu="6502">
  <!-- source: MAME technos/spdodgeb.cpp -->
  <!-- year: 1987 -->
  <memory_map>
    <region start="0x00000000" end="0x000010FF" type="ram" name="ram"/>
    <region start="0x00002000" end="0x00002FFF" type="ram" name="ram"/>
    <region start="0x00003000" end="0x00003001" type="unmapped" name="nop_write"/>
    <region start="0x00003002" end="0x00003002" type="io" name="write"/>
    <region start="0x00003003" end="0x00003003" type="unmapped" name="nop_write"/>
    <region start="0x00003004" end="0x00003006" type="io" name="scrollx_lo_w"/>
    <region start="0x00003800" end="0x00003805" type="io" name="write"/>
    <region start="0x00004000" end="0x00007FFF" type="ram" name="banked"/>
    <region start="0x00008000" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

