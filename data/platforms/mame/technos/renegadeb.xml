  <!-- year: 1986 -->
  <memory_map>
    <region start="0x00000000" end="0x000021FF" type="ram" name="ram"/>
    <region start="0x00002800" end="0x000031FF" type="ram" name="ram"/>
    <region start="0x00003800" end="0x00003803" type="io" name="scroll_lsb_w"/>
    <region start="0x00003805" end="0x00003805" type="unmapped" name="nop_read"/>
