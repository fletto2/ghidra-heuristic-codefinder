<platform name="midway" cpu="68000">
  <!-- source: MAME midway/midway.cpp -->
  <memory_map>
    <region start="0x00000000" end="0x00003FFF" type="rom" name="rom"/>
    <region start="0x00008000" end="0x000083FF" type="ram" name="ram"/>
    <region start="0x00009000" end="0x00009003" type="io" name="data_r"/>
    <region start="0x0000A000" end="0x0000A002" type="io" name="address_w"/>
    <region start="0x0000B000" end="0x0000B002" type="io" name="address_w"/>
    <region start="0x0000C000" end="0x0000DFFF" type="unmapped" name="nop_read"/>
    <region start="0x0000E000" end="0x0000FFFF" type="io" name="irq_clear"/>
  </memory_map>

  <vectors format="abs32_be" base="0x00000000">
    <entry index="0" name="initial_ssp"/>
    <entry index="1" name="reset_pc"/>
    <entry index="2" name="bus_error"/>
    <entry index="3" name="address_error"/>
    <entry index="4" name="illegal_instr"/>
