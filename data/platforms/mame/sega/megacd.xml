IRQ_CALLBACK_MEMBER(sega_segacd_device::segacd_sub_int_callback)
{
if (irqline==2)
{
// clear this bit
m_a12000_halt_reset_reg &amp;= ~0x0100;
m_scdcpu-&gt;set_input_line(2, CLEAR_LINE);
}
return (0x60+irqline*4)/4; // vector address
}
