<platform name="apple1" cpu="6502">
  <!-- source: MAME apple/apple1.cpp -->
  <!-- year: 1976 -->
  <memory_map>
    <region start="0x00000000" end="0x0000BFFF" type="io" name="ram_r"/>
    <region start="0x0000D010" end="0x0000D013" type="io" name="read"/>
    <region start="0x0000E000" end="0x0000EFFF" type="ram" name="ram"/>
    <region start="0x0000FF00" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

