<platform name="cbasebal" cpu="z80">
  <!-- source: MAME capcom/cbasebal.cpp -->
  <!-- year: 1989 -->
  <memory_map>
    <region start="0x00000000" end="0x00007FFF" type="rom" name="rom"/>
    <region start="0x00008000" end="0x0000BFFF" type="ram" name="banked"/>
    <region start="0x0000C000" end="0x0000CFFF" type="io" name="palette__vram__scrollram"/>
    <region start="0x0000E000" end="0x0000FFFF" type="ram" name="ram"/>
  </memory_map>

  <devices>
    <device type="sound" name="okim6295"/>
    <device type="storage" name="eeprom"/>
  </devices>

