<platform name="pangb2" cpu="z80">
  <!-- source: MAME capcom/mitchell.cpp -->
  <!-- year: 1989 -->
  <memory_map>
    <region start="0x00000000" end="0x00007FFF" type="rom" name="rom"/>
    <region start="0x00008000" end="0x0000BFFF" type="ram" name="banked"/>
    <region start="0x0000C000" end="0x0000C7FF" type="io" name="paletteram_r"/>
    <region start="0x0000C800" end="0x0000CFFF" type="ram" name="ram"/>
    <region start="0x0000D000" end="0x0000DFFF" type="io" name="videoram_r"/>
    <region start="0x0000E000" end="0x0000FFFF" type="ram" name="nvram"/>
  </memory_map>

  <devices>
    <device type="sound" name="okim6295"/>
    <device type="storage" name="eeprom"/>
  </devices>

  <!-- "Mitchell hardware". Actually used mostly by Capcom.
All games run on the same hardware except mgakuen, which runs on an
earlier version, without RAM banking, not encrypted (standard Z80)
and without EEPROM.
Notes:
- Super Pang has a protection which involves copying code stored in the
EEPROM to RAM and execute it from there. The first time the game is run,
you have to keep the player 1 start button pressed until the title screen
appears. This forces the game to initialize the EEPROM, otherwise ... -->
</platform>
