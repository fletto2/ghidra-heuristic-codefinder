<platform name="pokechmp" cpu="6502">
  <!-- source: MAME dgrm/pokechmp.cpp -->
  <!-- year: 1995 -->
  <memory_map>
    <region start="0x00000000" end="0x000011FF" type="ram" name="ram"/>
    <region start="0x00001800" end="0x00001801" type="io" name="port"/>
    <region start="0x00001802" end="0x0000181F" type="unmapped" name="nop_write"/>
    <region start="0x00001A00" end="0x00001A00" type="io" name="write"/>
    <region start="0x00001C00" end="0x00001C00" type="io" name="main_bank_w"/>
    <region start="0x00002000" end="0x000027FF" type="ram" name="palette_ext"/>
    <region start="0x00004000" end="0x00007FFF" type="ram" name="banked"/>
    <region start="0x00008000" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

  <devices>
    <device type="sound" name="okim6295"/>
  </devices>

  <!-- Poke Champ */
This is a Korean hack of Data East's Pocket Gal
It uses RAM for Palette instead of PROMs
Samples are played by OKIM6295
Different Banking
More Tiles, 8bpp
Sprites 4bpp instead of 2bpp
Many code changes -->
</platform>
