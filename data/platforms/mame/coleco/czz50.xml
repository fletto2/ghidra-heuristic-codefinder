<platform name="czz50" cpu="z80">
  <!-- source: MAME coleco/coleco.cpp -->
  <!-- year: 1986 -->
  <memory_map>
    <region start="0x00000000" end="0x00001FFF" type="rom" name="rom"/>
    <region start="0x00006000" end="0x000063FF" type="ram" name="ram"/>
    <region start="0x00008000" end="0x0000FFFF" type="io" name="cart_r"/>
  </memory_map>

  <!-- coleco.c
Driver file to handle emulation of the ColecoVision.
Marat Fayzullin (ColEm source)
Marcel de Kogel (AdamEm source)
Mike Balfour
Ben Bruscella
Sean Young
NEWS:
- Modified memory map, now it has only 1k of RAM mapped on 8k Slot
- Modified I/O map, now it is handled as on a real ColecoVision:
The I/O map is broken into 4 write and 4 read ports:
80-9F (W) = Set both controllers to keypad mode
80-9F (R) = Not Connected
A0-BF (W) = Video Chip (TMS9928A), A0=0 -&gt; Write Register 0 , A0=1 -&... -->
</platform>
