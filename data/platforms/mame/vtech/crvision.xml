<platform name="crvision" cpu="6502">
  <!-- source: MAME vtech/crvision.cpp -->
  <!-- year: 1982 -->
  <memory_map>
    <region start="0x00000000" end="0x000003FF" type="ram" name="ram"/>
    <region start="0x00001000" end="0x00001003" type="io" name="read"/>
    <region start="0x00002000" end="0x00002001" type="io" name="read"/>
    <region start="0x00003000" end="0x00003001" type="io" name="write"/>
    <region start="0x00004000" end="0x0000BFFF" type="ram" name="ram"/>
    <region start="0x0000C000" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

  <!-- This 1980s computer was manufactured by VTech of Hong Kong.
known as: CreatiVision, Dick Smith Wizzard, Funvision, Rameses, VZ 2000 and possibly others.
There is also a CreatiVision Mk 2, possibly also known as the Laser 500. This was a hardware variant,
sort of "evolved" hardware made compatible for the scheduled "ColecoVision expansion module", which
never actually shipped for CreatiVision, but for the Laser 2001 home computer (successor to
CreatiVision).
TODO:
