  <!-- year: 1975 -->
  <memory_map>
    <region start="0x00000000" end="0x00000FFF" type="rom" name="rom"/>
    <region start="0x00001000" end="0x000013FF" type="ram" name="ram"/>
  </memory_map>

  <devices>
    <device type="io" name="i8255"/>
  </devices>

  <!-- Intel SDK-80
The 8080 System Design Kit (SDK-80) is a complete microcomputer system in
kit form, and provides a excellent prototype vehicle for evaluation of the
