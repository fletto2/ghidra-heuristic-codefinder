<platform name="ds2" cpu="z80">
  <!-- source: MAME intel/rex6000.cpp -->
  <!-- year: 2000 -->
  <memory_map>
    <region start="0x00000000" end="0x0000BFFF" type="io" name="read"/>
    <region start="0x0000C000" end="0x0000FFFF" type="ram" name="ram"/>
  </memory_map>

  <devices>
    <device type="serial" name="8250"/>
    <device type="serial" name="ns16550"/>
  </devices>

  <!-- Xircom / Intel REX 6000
Driver by Sandro Ronco
Known REX 6000 banks:
0x0000 - 0x00ff     first flash chip
0x0600 - 0x06ff     second flash chip
0x1000 - 0x1003     32KB RAM
Known DataSlim 2 banks:
0x0000 - 0x00ff     first flash chip
0x0b00 - 0x0bff     second flash chip
0x1000 - 0x1003     32KB RAM
