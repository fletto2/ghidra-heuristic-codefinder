<platform name="spacefbb" cpu="z80">
  <!-- source: MAME nintendo/spacefb.cpp -->
  <!-- year: 1980 -->
  <memory_map>
    <region start="0x00000000" end="0x00003FFF" type="rom" name="rom"/>
    <region start="0x00004000" end="0x00007FFF" type="unmapped" name="unmapped"/>
    <region start="0x00008000" end="0x000083FF" type="ram" name="ram"/>
    <region start="0x0000C000" end="0x0000C7FF" type="ram" name="ram"/>
    <region start="0x0000C800" end="0x0000CFFF" type="unmapped" name="unmapped"/>
  </memory_map>

  <devices>
    <device type="sound" name="dac"/>
  </devices>

  <!-- Space Firebird hardware
Memory Map figured out by Chris Hardy, Paul Johnson and Andy Clark
