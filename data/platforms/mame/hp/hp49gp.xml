<platform name="hp49gp" cpu="arm9">
  <!-- source: MAME hp/hp49gp.cpp -->
  <!-- year: 2009 -->
  <memory_map>
    <region start="0x00000000" end="0x001FFFFF" type="rom" name="rom"/>
    <region start="0x08000000" end="0x0807FFFF" type="ram" name="ram"/>
    <region start="0x40000000" end="0x40000FFF" type="ram" name="steppingstone"/>
  </memory_map>

  <vectors format="abs32_le" base="0x00000000">
    <entry index="0" name="reset"/>
    <entry index="1" name="undef"/>
    <entry index="2" name="swi"/>
    <entry index="3" name="prefetch_abort"/>
    <entry index="4" name="data_abort"/>
    <entry index="6" name="irq" irq="true"/>
    <entry index="7" name="fiq" irq="true"/>
  </vectors>
</platform>
