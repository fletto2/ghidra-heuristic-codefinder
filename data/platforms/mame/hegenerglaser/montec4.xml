<platform name="montec4" cpu="65c02">
  <!-- source: MAME hegenerglaser/montec.cpp -->
  <!-- year: 1989 -->
  <memory_map>
    <region start="0x00000000" end="0x00001FFF" type="ram" name="nvram"/>
    <region start="0x00002000" end="0x00002000" type="io" name="irq_ack_r"/>
    <region start="0x00002400" end="0x00002400" type="io" name="input_r"/>
    <region start="0x00002800" end="0x00002800" type="io" name="mux_w"/>
    <region start="0x00002C00" end="0x00002C00" type="io" name="led_w"/>
    <region start="0x00003000" end="0x00003007" type="unmapped" name="nop_read"/>
    <region start="0x00003400" end="0x00003400" type="io" name="led_w"/>
    <region start="0x00008000" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

  <devices>
    <device type="sound" name="dac"/>
  </devices>

