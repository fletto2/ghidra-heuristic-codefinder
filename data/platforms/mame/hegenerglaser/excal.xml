<platform name="excal" cpu="68000">
  <!-- source: MAME hegenerglaser/excalibur.cpp -->
  <!-- year: 1983 -->
  <memory_map>
    <region start="0x00000000" end="0x0001FFFF" type="ram" name="ram"/>
    <region start="0x00000000" end="0x00000007" type="rom" name="rom"/>
    <region start="0x00020000" end="0x0002FFFF" type="rom" name="rom"/>
    <region start="0x0004C000" end="0x0004C00F" type="io" name="read"/>
    <region start="0x0005C000" end="0x0005C007" type="io" name="read"/>
    <region start="0x00100000" end="0x00100001" type="io" name="input_r"/>
    <region start="0x00200000" end="0x00200001" type="io" name="mux_w"/>
    <region start="0x00300000" end="0x00300001" type="io" name="led_w"/>
    <region start="0x00400000" end="0x0040001F" type="io" name="input_r"/>
    <region start="0x00800000" end="0x00800001" type="io" name="data_w"/>
  </memory_map>

  <vectors format="abs32_be" base="0x00000000">
    <entry index="0" name="initial_ssp"/>
    <entry index="1" name="reset_pc"/>
    <entry index="2" name="bus_error"/>
    <entry index="3" name="address_error"/>
    <entry index="4" name="illegal_instr"/>
    <entry index="5" name="divide_by_zero"/>
    <entry index="6" name="chk"/>
    <entry index="7" name="trapv"/>
    <entry index="8" name="privilege"/>
    <entry index="9" name="trace"/>
    <entry index="10" name="line_a"/>
    <entry index="11" name="line_f"/>
    <entry index="24" name="spurious_irq"/>
    <entry index="25" name="autovector_1" irq="true"/>
    <entry index="26" name="autovector_2" irq="true"/>
    <entry index="27" name="autovector_3" irq="true"/>
    <entry index="28" name="autovector_4" irq="true"/>
    <entry index="29" name="autovector_5" irq="true"/>
    <entry index="30" name="autovector_6" irq="true"/>
    <entry index="31" name="autovector_7" irq="true"/>
    <entry index="32" name="trap_0"/>
    <entry index="33" name="trap_1"/>
    <entry index="34" name="trap_2"/>
    <entry index="35" name="trap_3"/>
    <entry index="36" name="trap_4"/>
    <entry index="37" name="trap_5"/>
    <entry index="38" name="trap_6"/>
    <entry index="39" name="trap_7"/>
    <entry index="40" name="trap_8"/>
    <entry index="41" name="trap_9"/>
