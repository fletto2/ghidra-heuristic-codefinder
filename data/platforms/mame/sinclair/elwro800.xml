<platform name="elwro800" cpu="z80">
  <!-- source: MAME sinclair/elwro800.cpp -->
  <!-- year: 1986 -->
  <memory_map>
    <region start="0x00000000" end="0x00003FFF" type="io" name="region_0"/>
    <region start="0x00004000" end="0x0000FFFF" type="ram" name="rambank3"/>
  </memory_map>

  <devices>
    <device type="disk" name="upd765"/>
    <device type="io" name="i8255"/>
  </devices>

  <!-- Elwro 800 Junior
Driver by Mariusz Wojcieszek
ToDo:
- 8251 DTR and DTS signals are connected (with some additional logic) to NMI of Z80, this
is not emulated
- 8251 is used for JUNET network (a network of Elwro 800 Junior computers, allows sharing
floppy disc drives and printers) - network is not emulated -->
</platform>
