<platform name="barbball" cpu="6502">
  <!-- source: MAME atari/bartop52.cpp -->
  <!-- year: 1983 -->
  <memory_map>
    <region start="0x00000000" end="0x00003FFF" type="ram" name="ram"/>
    <region start="0x00004000" end="0x0000BFFF" type="rom" name="rom"/>
    <region start="0x0000C000" end="0x0000C0FF" type="io" name="read"/>
    <region start="0x0000D400" end="0x0000D5FF" type="io" name="read"/>
    <region start="0x0000E800" end="0x0000E8FF" type="io" name="read"/>
    <region start="0x0000F800" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

  <devices>
    <device type="sound" name="pokey"/>
  </devices>

  <!-- Atari Bartop 5200 prototype system
Driver by Mariusz Wojcieszek
Based on Atari 400/800 MAME Driver by Juergen Buchmueller
Hardware was based on Atari 5200 game console with additional coin and timer hardware.
System was intented to run in barrooms and taverns. Software was based on Atari 5200
Realsports cartridges.
Barroom Baseball is modified version of Realsports Baseball.
Coins and timer were handled by Bartop system bios. Since bios dump is not available,
regular Atari 5200 bios is used and ... -->
</platform>
