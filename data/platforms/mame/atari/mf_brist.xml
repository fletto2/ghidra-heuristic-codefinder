  <!-- year: 1983 -->
  <memory_map>
    <region start="0x00000000" end="0x00003FFF" type="ram" name="ram"/>
    <region start="0x00005000" end="0x000057FF" type="rom" name="rom"/>
    <region start="0x00008000" end="0x0000CFFF" type="rom" name="rom"/>
    <region start="0x0000D000" end="0x0000D0FF" type="io" name="read"/>
    <region start="0x0000D100" end="0x0000D1FF" type="unmapped" name="unmapped"/>
    <region start="0x0000D200" end="0x0000D4FF" type="io" name="read"/>
    <region start="0x0000D500" end="0x0000D7FF" type="unmapped" name="unmapped"/>
    <region start="0x0000D800" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

  <devices>
    <device type="sound" name="pokey"/>
  </devices>

