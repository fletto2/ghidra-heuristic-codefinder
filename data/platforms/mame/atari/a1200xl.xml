<platform name="a1200xl" cpu="6502">
  <!-- source: MAME atari/atari400.cpp -->
  <!-- year: 1982 -->
  <memory_map>
    <region start="0x00000000" end="0x00003FFF" type="ram" name="ram"/>
    <region start="0x00004000" end="0x0000CFFF" type="io" name="cart"/>
    <region start="0x0000D400" end="0x0000D4FF" type="io" name="read"/>
    <region start="0x0000E800" end="0x0000EFFF" type="io" name="read"/>
    <region start="0x0000F000" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

  <devices>
    <device type="sound" name="dac"/>
    <device type="sound" name="pokey"/>
  </devices>

