<platform name="cexpert" cpu="65c02">
  <!-- source: MAME novag/cexpert.cpp -->
  <!-- year: 1985 -->
  <memory_map>
    <region start="0x00000000" end="0x00000FFF" type="ram" name="nvram"/>
    <region start="0x00001000" end="0x00001000" type="unmapped" name="nop_write"/>
    <region start="0x00001100" end="0x00001100" type="unmapped" name="nop_write"/>
    <region start="0x00001200" end="0x00001200" type="io" name="input2_r"/>
    <region start="0x00001300" end="0x00001300" type="io" name="input1_r"/>
    <region start="0x00001800" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

  <!-- Novag Constellation Expert (model 853)
