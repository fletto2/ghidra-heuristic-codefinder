<platform name="s1945iiibl" cpu="sh2">
  <!-- source: MAME psikyo/psikyosh.cpp -->
  <!-- year: 1999 -->
  <memory_map>
    <region start="0x00000000" end="0x001FFFFF" type="rom" name="rom"/>
    <region start="0x04003000" end="0x040031FF" type="ram" name="zoomram"/>
    <region start="0x04050000" end="0x040501FF" type="unmapped" name="unmapped"/>
    <region start="0x04053FDC" end="0x04053FDF" type="unmapped" name="nop_read"/>
    <region start="0x04053FE0" end="0x04053FFF" type="ram" name="vidregs"/>
    <region start="0x0405FFDC" end="0x0405FFFF" type="unmapped" name="unmapped"/>
    <region start="0x05000000" end="0x0507FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs32_be" base="0x00000000">
    <entry index="0" name="power_on_pc"/>
    <entry index="1" name="power_on_sp"/>
    <entry index="2" name="manual_reset_pc"/>
    <entry index="3" name="manual_reset_sp"/>
    <entry index="4" name="general_illegal"/>
    <entry index="6" name="slot_illegal"/>
    <entry index="9" name="cpu_addr_error"/>
    <entry index="10" name="dma_addr_error"/>
    <entry index="11" name="nmi" irq="true"/>
    <entry index="12" name="user_break"/>
  </vectors>

  <devices>
    <device type="storage" name="eeprom"/>
  </devices>

  <!-- ----------------------------------------------------------------
Psikyo PS3/PS5/PS5v2 SH-2 Based Systems
driver by David Haywood (+ Paul Priest)
thanks to Farfetch'd for information about the sprite zoom table.
------------------------------------------------------------------
Moving on from the 68020 based system used for the first Strikers
1945 game Psikyo introduced a system using Hitachi's SH-2 CPU
This driver is for the single-screen PS3/PS5/PS5v2 boards
There appear to be multiple revision... -->
</platform>
