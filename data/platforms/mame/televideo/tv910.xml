<platform name="tv910" cpu="6502">
  <!-- source: MAME televideo/tv910.cpp -->
  <!-- year: 1981 -->
  <memory_map>
    <region start="0x00000000" end="0x000003FF" type="ram" name="ram"/>
    <region start="0x00004000" end="0x000047FF" type="ram" name="vram"/>
    <region start="0x00008010" end="0x00008021" type="io" name="charset_r"/>
    <region start="0x00008030" end="0x00008033" type="io" name="read"/>
    <region start="0x00008040" end="0x0000807F" type="io" name="vbl_ack_w"/>
    <region start="0x00009000" end="0x00009002" type="io" name="control_w"/>
    <region start="0x0000F000" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

  <devices>
    <device type="video" name="mc6845"/>
  </devices>

  <!-- TeleVideo Model 910 / 910 Plus
Hardware:
6502 CPU
6545 CRTC
6551 ACIA
IRQ = ACIA gated with flip-flop driven by CRTC VBlank (not wire-OR)
NMI = AY-5-3600 keyboard char present
Esc-V (with a capital V) brings up the self-test screen.
