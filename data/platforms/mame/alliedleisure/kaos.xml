<platform name="kaos" cpu="6502">
  <!-- source: MAME alliedleisure/killcom.cpp -->
  <!-- year: 1981 -->
  <memory_map>
    <region start="0x00000000" end="0x000003FF" type="ram" name="ram"/>
    <region start="0x00002000" end="0x0000200F" type="io" name="map"/>
    <region start="0x00002800" end="0x0000280F" type="io" name="map"/>
    <region start="0x00003000" end="0x0000300F" type="io" name="map"/>
    <region start="0x00008000" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

