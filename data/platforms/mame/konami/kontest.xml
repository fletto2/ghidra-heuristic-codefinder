<platform name="kontest" cpu="z80">
  <!-- source: MAME konami/kontest.cpp -->
  <memory_map>
    <region start="0x00000000" end="0x00007FFF" type="rom" name="rom"/>
    <region start="0x0000E000" end="0x0000FFFF" type="ram" name="ram"/>
  </memory_map>

  <devices>
    <device type="sound" name="sn76496"/>
  </devices>

  <!-- GX800 (Konami Test board)
driver by Angelo Salese
Notes:
Z80, 8KB RAM, 2 * SN76489AN for sound, TTLs for video/misc
There are 5 x 005273 (Konami custom resistor array (SIL10)) on the PCB,
also seen on Jail Break HW
menu translation:
screen distortion adjustment normal
screen distortion adjustment wide
input/output check
color check
sound check -->
</platform>
