<platform name="y532xl" cpu="65c02">
  <!-- source: MAME yeno/532xl.cpp -->
  <!-- year: 1989 -->
  <memory_map>
    <region start="0x00000000" end="0x00001FFF" type="ram" name="nvram"/>
    <region start="0x00002000" end="0x00002000" type="io" name="cb_w"/>
    <region start="0x00002080" end="0x00002080" type="io" name="led_w"/>
    <region start="0x00002100" end="0x00002100" type="io" name="input_r"/>
    <region start="0x00002180" end="0x00002187" type="io" name="control_w"/>
    <region start="0x00008000" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

  <devices>
    <device type="sound" name="dac"/>
  </devices>

  <!-- Yeno 532 XL
This is the only Yeno chesscomputer that has a common CPU with external EPROM,
others are based on a 1-chip MCU. The 532 XL chess engine is by Ulf Rathsman.
Hardware notes:
- R65C02P4 @ 4 MHz
- 32KB ROM (MBM27C256H-10)
- 8KB battery-backed RAM (HY6264LP-10)
- HD61603, 2 4*7seg LCD screens
- TTL, piezo, 8*8+7 LEDs, button sensors
The software searches for an opening book ROM in 0x4000-0x7fff, it looks like
it's compatible with Conchess L16 / Mephisto HG240. Though the hardware does
no... -->
</platform>
