<platform name="tulip1" cpu="8086">
  <!-- source: MAME skeleton/tulip1.cpp -->
  <!-- year: 1983 -->
  <memory_map>
    <region start="0x00000000" end="0x0001FFFF" type="ram" name="ram"/>
    <region start="0x00020000" end="0x000DFFFF" type="unmapped" name="unmapped"/>
    <region start="0x000E0000" end="0x000E0FFF" type="ram" name="vram"/>
    <region start="0x000FE000" end="0x000FFFFF" type="rom" name="rom"/>
  </memory_map>

  <devices>
    <device type="disk" name="wd_fdc"/>
    <device type="serial" name="acia6850"/>
    <device type="video" name="hd6845"/>
    <device type="video" name="mc6845"/>
  </devices>

