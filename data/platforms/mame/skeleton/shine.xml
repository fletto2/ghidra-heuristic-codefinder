<platform name="shine" cpu="6502">
  <!-- source: MAME skeleton/shine.cpp -->
  <!-- year: 1983 -->
  <memory_map>
    <region start="0x00000000" end="0x00007FFF" type="ram" name="ram"/>
    <region start="0x00009400" end="0x0000940F" type="io" name="map"/>
    <region start="0x00009800" end="0x0000980F" type="io" name="map"/>
    <region start="0x00009C00" end="0x00009C03" type="io" name="read"/>
    <region start="0x00009D00" end="0x00009D00" type="io" name="floppy_w"/>
    <region start="0x0000B000" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

  <devices>
    <device type="disk" name="wd_fdc"/>
  </devices>

  <!-- Shine/1
TODO: everything to be verified.
The system rom has an inbuilt monitor program - unknown how to access it.
The floppy disk is accessed via an "expansion" socket on the back. Inbuilt commands
such as DIR [1|2], RENAME, ERASE, PROT, XFER look interesting. The DIR command does
multiple reads of 0x9E00.
There's a DIN socket for cassette. Commands BAUD, SAVE, LOAD appear to be the ones
but the syntax has yet to be worked out. BAUD [0-9] is allowed but what is it doing? -->
</platform>
