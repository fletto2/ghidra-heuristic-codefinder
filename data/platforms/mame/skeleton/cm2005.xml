<platform name="cm2005" cpu="arm7_le">
  <!-- source: MAME skeleton/dyna_d0404.cpp -->
  <!-- year: 2005 -->
  <memory_map>
    <region start="0x00000000" end="0x000FFFFF" type="rom" name="rom"/>
    <region start="0x00200000" end="0x0020BFFF" type="ram" name="ram"/>
    <region start="0x00240000" end="0x0024FFFF" type="ram" name="ram"/>
    <region start="0xFFFF0000" end="0xFFFFFFFF" type="ram" name="ram"/>
  </memory_map>

  <vectors format="abs32_le" base="0x00000000">
    <entry index="0" name="reset"/>
    <entry index="1" name="undef"/>
    <entry index="2" name="swi"/>
    <entry index="3" name="prefetch_abort"/>
    <entry index="4" name="data_abort"/>
    <entry index="6" name="irq" irq="true"/>
    <entry index="7" name="fiq" irq="true"/>
  </vectors>

  <devices>
    <device type="rtc" name="msm6242"/>
  </devices>

  <!-- Dyna D0404 PCB
This PCB is newer hardware than the one is misc/cb2001.cpp, possibly the next one.
It seems Dyna got rid of some legacy features like physical DIPs, color PROMs and AY sound.
While the CPU is sanded off, ROM seems to contain valid ARM code.
Currently unknown what produces the sound.
The main components are:
208-pin custom (sanded off). MCU/CPU?
176-pin custom (sanded off). GFX?
4x AMIC LP61 1024S-12 SRAM or equivalent (for CPU?)
2x IDT71024 SRAM or equivalent (for GFX?)
2x A625308... -->
</platform>
