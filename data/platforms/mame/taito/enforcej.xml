<platform name="enforcej" cpu="68000">
  <!-- source: MAME taito/taito_z.cpp -->
  <!-- year: 1988 -->
  <memory_map>
    <region start="0x00000000" end="0x0003FFFF" type="rom" name="rom"/>
    <region start="0x00100000" end="0x00107FFF" type="ram" name="ram"/>
    <region start="0x00200001" end="0x00200001" type="io" name="contcirc_out_w"/>
    <region start="0x00300000" end="0x003006FF" type="ram" name="spriteram"/>
    <region start="0x00400000" end="0x00401FFF" type="io" name="word_r"/>
