<platform name="obdmx" cpu="z80">
  <!-- source: MAME oberheim/dmx.cpp -->
  <!-- year: 1980 -->
  <memory_map>
    <region start="0x00000000" end="0x00001FFF" type="rom" name="rom"/>
    <region start="0x00002000" end="0x00003FFF" type="ram" name="ram"/>
  </memory_map>

  <devices>
    <device type="sound" name="dac"/>
  </devices>

