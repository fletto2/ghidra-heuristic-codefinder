<platform name="mt65" cpu="6502">
  <!-- source: MAME tangerine/microtan.cpp -->
  <!-- year: 1979 -->
  <memory_map>
    <region start="0x00000000" end="0x0000FFFF" type="io" name="read"/>
    <region start="0x00000000" end="0x000003FF" type="ram" name="ram"/>
    <region start="0x0000BFF0" end="0x0000BFFF" type="io" name="bffx_r"/>
    <region start="0x0000F800" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

