<platform name="begas1" cpu="6502">
  <!-- source: MAME dataeast/deco_ld.cpp -->
  <!-- year: 1983 -->
  <memory_map>
    <region start="0x00000000" end="0x00000FFF" type="ram" name="ram"/>
    <region start="0x00001000" end="0x00001000" type="unmapped" name="nop_write"/>
    <region start="0x00001001" end="0x00001007" type="io" name="port"/>
    <region start="0x00001006" end="0x00001007" type="io" name="acia_status_hack_r"/>
    <region start="0x00001800" end="0x000027FF" type="ram" name="palette"/>
    <region start="0x00003000" end="0x000037FF" type="ram" name="ram"/>
    <region start="0x00004000" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

  <devices>
    <device type="serial" name="acia6850"/>
    <device type="sound" name="ay8910"/>
  </devices>

