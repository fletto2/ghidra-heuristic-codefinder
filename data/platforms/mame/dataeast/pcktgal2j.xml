<platform name="pcktgal2j" cpu="6502">
  <!-- source: MAME dataeast/pcktgal.cpp -->
  <!-- year: 1989 -->
  <memory_map>
    <region start="0x00000000" end="0x000007FF" type="ram" name="ram"/>
    <region start="0x00000800" end="0x00000801" type="io" name="write"/>
    <region start="0x00001000" end="0x00001001" type="io" name="write"/>
    <region start="0x00001800" end="0x00001800" type="io" name="adpcm_data_w"/>
    <region start="0x00002000" end="0x00002000" type="io" name="sound_bank_w"/>
    <region start="0x00003000" end="0x00003000" type="io" name="read"/>
    <region start="0x00003400" end="0x00003400" type="io" name="sound_unk_r"/>
    <region start="0x00004000" end="0x00007FFF" type="ram" name="banked"/>
    <region start="0x00008000" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

