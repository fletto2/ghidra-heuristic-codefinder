<platform name="dommy" cpu="6502">
  <!-- source: MAME dataeast/btime.cpp -->
  <!-- year: 1983 -->
  <memory_map>
    <region start="0x00000000" end="0x000007FF" type="ram" name="ram"/>
    <region start="0x00002000" end="0x000027FF" type="ram" name="ram"/>
    <region start="0x00002800" end="0x00002BFF" type="io" name="btime_mirrorvideoram_r"/>
    <region start="0x00004000" end="0x00004007" type="io" name="irqack_w"/>
    <region start="0x0000A000" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

  <devices>
    <device type="sound" name="ay8910"/>
  </devices>

  <!-- Burger Time
driver by Zsolt Vasvari
