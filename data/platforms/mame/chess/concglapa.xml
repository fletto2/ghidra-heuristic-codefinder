<platform name="concglapa" cpu="6502">
  <!-- source: MAME chess/conchess.cpp -->
  <!-- year: 1984 -->
  <memory_map>
    <region start="0x00000000" end="0x00000FFF" type="ram" name="ram"/>
    <region start="0x00001000" end="0x00001000" type="io" name="input_r"/>
    <region start="0x00001000" end="0x0000100F" type="io" name="leds_w"/>
    <region start="0x00001800" end="0x00001800" type="io" name="sound_w"/>
    <region start="0x00004000" end="0x00007FFF" type="io" name="rom"/>
    <region start="0x00008000" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

  <!-- Conchess, a series of modular chess computers by Consumenta Computer.
Hardware design by Loproc GmbH (Germany, formerly EES), manufactured at Waltham
Electronics (Ireland). The core people involved were Ulf Rathsman for the chess
engine, and Johan Enroth. After Consumenta went under in 1982 before production
started, and then Waltham in 1983, the Conchess brand was continued by Princhess
AB and Systemhuset.
