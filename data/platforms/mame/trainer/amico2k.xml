<platform name="amico2k" cpu="6502">
  <!-- source: MAME trainer/amico2k.cpp -->
  <!-- year: 1978 -->
  <memory_map>
    <region start="0x00000000" end="0x000007FF" type="ram" name="ram"/>
    <region start="0x0000FB00" end="0x0000FCFF" type="rom" name="rom"/>
    <region start="0x0000FD00" end="0x0000FD03" type="io" name="read"/>
    <region start="0x0000FE00" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

  <devices>
    <device type="io" name="i8255"/>
  </devices>

