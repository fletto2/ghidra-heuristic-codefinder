<platform name="mac3" cpu="6502">
  <!-- source: MAME trainer/mac3.cpp -->
  <!-- year: 1990 -->
  <memory_map>
    <region start="0x00000000" end="0x00001FFF" type="ram" name="ram"/>
    <region start="0x00007000" end="0x00007000" type="io" name="display_latch_w"/>
    <region start="0x00008000" end="0x0000800F" type="io" name="read"/>
    <region start="0x00009000" end="0x0000900F" type="io" name="map"/>
    <region start="0x0000A000" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

  <devices>
    <device type="serial" name="mc68681"/>
    <device type="serial" name="scn2681"/>
  </devices>

  <!-- Mac III by L.J.Technical Systems
Keys:
0-9,A-F: hex input
M      : memory display and edit
P      : port display and edit
L      : load from cassette
S      : save to cassette
G      : program run
R      : register display and edit
+      : up (use UP-arrow key)
-      : down (use DOWN-arrow key)
TODO:
- fix cassette interface, maybe a SCN2681 issue.
- keypad logic is guessed, need schematic. -->
</platform>
