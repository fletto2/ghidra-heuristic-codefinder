<platform name="chesster" cpu="65c02">
  <!-- source: MAME fidelity/chesster.cpp -->
  <!-- year: 1990 -->
  <memory_map>
    <region start="0x00000000" end="0x00001FFF" type="ram" name="ram"/>
    <region start="0x00002000" end="0x00002007" type="io" name="input_r"/>
    <region start="0x00004000" end="0x00007FFF" type="ram" name="banked"/>
    <region start="0x00006000" end="0x00006000" type="io" name="data_w"/>
    <region start="0x00008000" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

  <devices>
    <device type="sound" name="dac"/>
  </devices>

  <!-- Fidelity Chesster Challenger
These were made after Hegener + Glaser became the parent company of Fidelity
(design phase started before that). Kishon Chesster was released under both
Fidelity and Mephisto brands. Fidelity changed from Fidelity International,
Inc. to Fidelity Electronics International, Inc. after becoming a subsidiary.
================================================================================
Fidelity Chesster (model 6120)
There is also a German version titled Kishon Chesste... -->
</platform>
