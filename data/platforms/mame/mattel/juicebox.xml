<platform name="juicebox" cpu="arm7_le">
  <!-- source: MAME mattel/juicebox.cpp -->
  <!-- year: 2004 -->
  <memory_map>
    <region start="0x00000000" end="0x007FFFFF" type="rom" name="rom"/>
    <region start="0x04000000" end="0x04FFFFFF" type="io" name="juicebox_nand_r"/>
    <region start="0x0C000000" end="0x0C1FFFFF" type="ram" name="ram"/>
  </memory_map>

  <vectors format="abs32_le" base="0x00000000">
    <entry index="0" name="reset"/>
    <entry index="1" name="undef"/>
    <entry index="2" name="swi"/>
    <entry index="3" name="prefetch_abort"/>
    <entry index="4" name="data_abort"/>
    <entry index="6" name="irq" irq="true"/>
    <entry index="7" name="fiq" irq="true"/>
  </vectors>

  <devices>
    <device type="sound" name="dac"/>
  </devices>

  <!-- Mattel Juice Box
(C) 2011 Tim Schuerewegen -->
</platform>
