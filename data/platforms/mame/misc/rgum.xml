<platform name="rgum" cpu="6502">
  <!-- source: MAME misc/rgum.cpp -->
  <!-- year: 1993 -->
  <memory_map>
    <region start="0x00000000" end="0x000007FF" type="ram" name="ram"/>
    <region start="0x00000800" end="0x00000801" type="io" name="address_w"/>
    <region start="0x00002000" end="0x00002000" type="io" name="aysnd_2000_w"/>
    <region start="0x00002002" end="0x00002002" type="io" name="data_r"/>
    <region start="0x00002800" end="0x00002803" type="io" name="upd_data_w"/>
    <region start="0x00002C00" end="0x00002C03" type="io" name="write"/>
    <region start="0x00003000" end="0x00003003" type="io" name="read"/>
    <region start="0x00004000" end="0x000047FF" type="ram" name="ram"/>
    <region start="0x00005000" end="0x000057FF" type="ram" name="ram"/>
    <region start="0x00008000" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

  <devices>
    <device type="io" name="i8255"/>
    <device type="sound" name="ay8910"/>
    <device type="video" name="mc6845"/>
  </devices>

