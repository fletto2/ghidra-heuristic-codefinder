<platform name="magicfly" cpu="6502">
  <!-- source: MAME misc/magicfly.cpp -->
  <memory_map>
    <region start="0x00000000" end="0x000007FF" type="ram" name="nvram"/>
    <region start="0x00000800" end="0x00000801" type="io" name="address_w"/>
    <region start="0x00001000" end="0x000013FF" type="ram" name="videoram"/>
    <region start="0x00001800" end="0x00001BFF" type="ram" name="colorram"/>
    <region start="0x00002800" end="0x00002800" type="io" name="mux_port_r"/>
    <region start="0x00003000" end="0x00003000" type="io" name="mux_port_w"/>
    <region start="0x0000C000" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

  <devices>
    <device type="sound" name="dac"/>
    <device type="video" name="mc6845"/>
  </devices>

