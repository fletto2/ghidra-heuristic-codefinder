<platform name="highvdeo" cpu="80186">
  <!-- source: MAME misc/highvdeo.cpp -->
  <memory_map>
    <region start="0x00000000" end="0x0000FFFF" type="ram" name="ram"/>
    <region start="0x00040000" end="0x000BFFFF" type="ram" name="blit_ram"/>
    <region start="0x000C0000" end="0x000FFFFF" type="rom" name="rom"/>
  </memory_map>

  <devices>
    <device type="sound" name="dac"/>
  </devices>

  <!-- High Video Tour 4000
Driver by Mirko Buffoni.
Original brasil.c by David Haywood &amp; Angelo Salese.
Additional work by Roberto Fresca.
Memory layout:
000000-0003FF   Interrupt table
