<platform name="alinvade" cpu="6502">
  <!-- source: MAME misc/alinvade.cpp -->
  <memory_map>
    <region start="0x00000000" end="0x000001FF" type="ram" name="ram"/>
    <region start="0x00000400" end="0x00000DFF" type="ram" name="videoram"/>
    <region start="0x00002000" end="0x00002000" type="io" name="sound_w"/>
    <region start="0x00004000" end="0x00004000" type="io" name="port"/>
    <region start="0x00006000" end="0x00006000" type="io" name="port"/>
    <region start="0x00008000" end="0x00008004" type="io" name="port"/>
    <region start="0x0000A000" end="0x0000A000" type="unmapped" name="nop_write"/>
    <region start="0x0000C000" end="0x0000C00F" type="rom" name="rom"/>
    <region start="0x0000E000" end="0x0000E3FF" type="rom" name="rom"/>
    <region start="0x0000E400" end="0x0000E400" type="io" name="sounden_w"/>
    <region start="0x0000E800" end="0x0000E800" type="io" name="irqmask_r"/>
    <region start="0x0000EC00" end="0x0000FFFF" type="rom" name="rom"/>
  </memory_map>

  <vectors format="abs16_le" base="0x0000FFFA">
    <entry index="0" name="nmi" irq="true"/>
    <entry index="1" name="reset"/>
    <entry index="2" name="irq" irq="true"/>
  </vectors>

